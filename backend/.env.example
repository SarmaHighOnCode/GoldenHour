# GoldenHour backend configuration.
# Copy to `.env` and fill in to enable each subsystem. With everything blank the
# API runs in demo mode (in-memory store, estimated ETAs, console link delivery).

# --- Supabase / PostgreSQL + PostGIS ---------------------------------------
# Set both to switch the data layer onto the real database.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Direct Postgres connection (used by seed_supabase.py / migrations).
DATABASE_URL=

# --- Google Maps Distance Matrix (real drive-time ETAs) --------------------
GOOGLE_MAPS_API_KEY=

# --- SMS gateway (MSG91 / Gupshup) — stretch goal --------------------------
MSG91_AUTH_KEY=

# --- Confirmation link delivery --------------------------------------------
# Public URL of the frontend; confirmation links are FRONTEND_URL/confirm/<token>
FRONTEND_URL=http://localhost:5173
# console | telegram | msg91
DELIVERY_CHANNEL=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CORS ------------------------------------------------------------------
# Comma-separated allowed origins; * for local dev.
CORS_ORIGINS=*

# --- Algorithm tuning (optional; sensible defaults baked in) ----------------
RANKING_TOP_N=5
ETA_MAX_MINUTES=30
DONOR_RADIUS_METERS=5000
DONOR_COOLDOWN_DAYS=90
CITY_AVG_SPEED_KMPH=22
